# ==========================================
# SAWS - Saudi AgriDrought Warning System
# Environment Variables Template
# ==========================================
# Copy this file to .env and fill in your values

# ==========================================
# FRONTEND CONFIGURATION
# ==========================================

# API Configuration
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/api/v1/ws/alerts

# Feature Flags
VITE_ENABLE_WEBSOCKET=true
VITE_ENABLE_MOCK_FALLBACK=false

# ==========================================
# BACKEND CONFIGURATION
# ==========================================

# Application Settings
APP_NAME=SAWS
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true

# Server Settings
HOST=0.0.0.0
PORT=8000
WORKERS=1

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=

# ==========================================
# DATABASE CONFIGURATION
# ==========================================

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=saws_user
DB_PASSWORD=change-this-password
DB_NAME=saws_db
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# Database URL (auto-constructed, but can override)
# DATABASE_URL=postgresql+asyncpg://saws_user:change-this-password@localhost:5432/saws_db

# ==========================================
# REDIS CONFIGURATION
# ==========================================

# Redis Server
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ==========================================
# SECURITY CONFIGURATION
# ==========================================

# JWT Secret (MUST be at least 32 characters in production!)
SECRET_KEY=change-this-secret-key-min-32-characters-for-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# API Keys (if using external services)
# ENCRYPTION_KEY=

# CORS Settings
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ==========================================
# GOOGLE EARTH ENGINE
# ==========================================

# Service Account Authentication
GEE_SERVICE_ACCOUNT_EMAIL=
GEE_SERVICE_ACCOUNT_KEY_PATH=/path/to/service-account-key.json
GEE_PROJECT_ID=

# ==========================================
# WEATHER API (PME - Presidency of Meteorology & Environment)
# ==========================================

PME_API_KEY=
PME_API_BASE_URL=https://api.pme.gov.sa
PME_API_TIMEOUT=30

# ==========================================
# EMAIL/SMTP CONFIGURATION
# ==========================================

# SMTP Settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@saws.gov.sa
SMTP_FROM_NAME=SAWS Alerts
SMTP_USE_TLS=true

# ==========================================
# CELERY CONFIGURATION
# ==========================================

# Celery Broker (Redis)
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Celery Settings
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_ACCEPT_CONTENT=json
CELERY_TIMEZONE=Asia/Riyadh
CELERY_ENABLE_UTC=true

# ==========================================
# SATELLITE DATA CONFIGURATION
# ==========================================

# MODIS
MODIS_COLLECTION=MODIS/006/MOD13Q1
MODIS_BAND=NDCVI

# Landsat
LANDSAT_COLLECTION=LANDSAT/LC08/C02/T1_L2
LANDSAT_CLOUD_FILTER=60

# Sentinel-2
SENTINEL2_COLLECTION=COPERNICUS/S2_SR_HARMONIZED

# ==========================================
# SAUDI EASTERN PROVINCE CONFIGURATION
# ==========================================

# Geographic Bounds (EPSG:4326 / WGS84)
# Eastern Province: Extended to 45°E to include Hafar Al-Batin
EP_MIN_LON=45.0
EP_MAX_LON=55.0
EP_MIN_LAT=24.0
EP_MAX_LAT=28.0

# Default Coordinate System
DEFAULT_CRS=EPSG:4326

# ==========================================
# MONITORING & TELEMETRY
# ==========================================

# Prometheus Metrics
ENABLE_METRICS=true
METRICS_PORT=9090

# Sentry Error Tracking
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# ==========================================
# DEVELOPMENT SETTINGS
# ==========================================

# Auto-reload on file changes
RELOAD=true

# Show API documentation
DOCS_URL=/docs
REDOC_URL=/redoc

# Allow CORS for all origins in development (SECURITY: Disable in production!)
ALLOW_ALL_CORS=false

# ==========================================
# PRODUCTION SETTINGS (set to true in production)
# ==========================================

# Production mode
# ENVIRONMENT=production
# DEBUG=false
# WORKERS=4
# RELOAD=false
# DOCS_URL=null
# REDOC_URL=null

# Security
# ALLOW_ALL_CORS=false
# REQUIRE_HTTPS=true

# Performance
# DB_POOL_SIZE=20
# DB_MAX_OVERFLOW=40
